# Variáveis de ambiente — API GestaGlic

MONGODB_URL=
RESEND_API_KEY=
EMAIL_FROM=noreply@seusite.com.br
APP_URL=https://seusite.com.br
# Segurança
JWT_SECRET=
JWT_EXPIRES_IN=30d
# Legado — use JWT_SECRET em produção
NEXT_PUBLIC_JWT_KEY=
ALLOWED_ORIGINS=https://app.gestaglic.com.br,https://gestaglic.com.br,https://admin.gestaglic.com.br

# Push notifications
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Protege cron jobs (POST /push/reminders e POST /payments/remind-pending)
CRON_SECRET=
ADMIN_EMAILS=seuemail@seusite.com.br
# Opcional — só um atalho no dashboard (não busca dados da Vercel)
# Use o analytics do app principal, não do admin:
# VERCEL_ANALYTICS_URL=https://vercel.com/my-team-58e42a93/seusite-app/analytics?environment=all

# AWS S3 (upload de fotos)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
BUCKET_NAME=

# Asaas (pagamento premium PDF)
ASAAS_API_KEY=
# Alternativa se o Vercel remover o "$": base64 da chave completa (echo -n '$aact_prod_...' | base64)
ASAAS_API_KEY_B64=
ASAAS_SANDBOX=true
ASAAS_WALLET_ID=
ASAAS_WEBHOOK_TOKEN=
